VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_PLACE_ID=

# Supabase project (Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (generate with: npx web-push generate-vapid-keys)
# The private key goes in Supabase function secrets, never here.
VITE_VAPID_PUBLIC_KEY=

# Cloudflare R2 (for booking reference image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: custom public domain for R2 bucket (e.g. https://refs.yourdomain.com)
# If not set, uses the default r2.dev public URL
R2_PUBLIC_URL=
